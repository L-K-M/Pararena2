<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the Pararena 2 macOS .app bundle.

  The release workflow (.github/workflows/release.yml) copies this into
  Pararena2.app/Contents/Info.plist and substitutes __VERSION__ with the release
  version (the git tag, minus its leading "v"). The bundled binary is the static
  universal build; the asset pack rides in Contents/Resources, which is what
  SDL_GetBasePath() returns for a bundle — so the port's existing search finds it.
-->
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>Pararena 2</string>
	<key>CFBundleDisplayName</key>
	<string>Pararena 2</string>
	<key>CFBundleIdentifier</key>
	<string>com.softdorothy.pararena2</string>
	<key>CFBundleExecutable</key>
	<string>pararena2</string>
	<key>CFBundleIconFile</key>
	<string>pararena.icns</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleShortVersionString</key>
	<string>__VERSION__</string>
	<key>CFBundleVersion</key>
	<string>__VERSION__</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
</dict>
</plist>
